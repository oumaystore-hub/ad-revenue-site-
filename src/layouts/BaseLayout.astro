---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title, description, image, article } = Astro.props;
const siteUrl = 'https://oumaystore-hub.github.io/ad-revenue-site';
const ogImage = image || `${siteUrl}/og-default.jpg`;
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} | TH Tech` : 'TH Tech'}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&family=Inter:wght@700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  </head>
  <body>
    <div class="reading-progress-bar" id="readingProgressBar"></div>
    <Header />
    <main><slot /></main>
    <Footer />
    <button id="backToTop" title="العودة للأعلى"><i class="fa-solid fa-arrow-up"></i></button>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('themeBtn');
        if (btn) {
          btn.addEventListener('click', () => {
            document.body.classList.toggle('dark-mode');
            btn.classList.toggle('active');
          });
        }
      });
    </script>

    <style>
      body {
        font-family: 'Cairo', sans-serif;
        margin: 0;
        font-size: 16px;
        line-height: 1.7;
        background: #f8fafc;
        color: #1e293b;        transition: all 0.3s ease;
      }

      body.dark-mode {
        background: #0f172a;
        color: #f1f5f9;
      }

      body.dark-mode .site-header {
        background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
      }

      body.dark-mode .article-container,
      body.dark-mode .cat-card,
      body.dark-mode .nav-item,
      body.dark-mode .intro {
        background: #1e293b;
        color: #cbd5e1;
        border-color: #334155;
      }

      body.dark-mode h1, body.dark-mode h2, body.dark-mode h3 {
        color: #f1f5f9;
      }

      body.dark-mode p, body.dark-mode .article-meta {
        color: #cbd5e1;
      }

      body.dark-mode .ad-slot {
        background: #334155;
        border-color: #475569;
      }

      body.dark-mode .article-content h2 {
        color: #60a5fa;
        border-right-color: #60a5fa;
      }

      body.dark-mode .article-badge {
        background: #1e40af;
        color: #bfdbfe;
      }

      body.dark-mode .back-btn {
        background: #334155;
        color: #cbd5e1;
      }

      body.dark-mode .back-btn:hover {        background: #475569;
        color: #f1f5f9;
      }

      .reading-progress-bar {
        position: fixed;
        top: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #3b82f6 0%, #60a5fa 100%);
        width: 0%;
        z-index: 9999;
        transition: width 0.1s ease;
      }

      #backToTop {
        position: fixed;
        bottom: 2rem;
        left: 2rem;
        background: #3b82f6;
        color: white;
        width: 45px;
        height: 45px;
        border-radius: 50%;
        border: none;
        cursor: pointer;
        display: none;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4);
        transition: 0.3s;
        z-index: 999;
      }
      #backToTop:hover {
        background: #1e3a8a;
        transform: translateY(-3px);
      }
      #backToTop.visible {
        display: flex;
      }

      .article-wrapper {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 2rem;
        max-width: 1200px;
        margin: 2rem auto;
        padding: 0 1.5rem;
      }      .article-main { min-width: 0; }
      .article-sidebar { position: relative; }
      @media (max-width: 1024px) {
        .article-wrapper {
          grid-template-columns: 1fr;
          gap: 1.5rem;
        }
        .article-sidebar { order: -1; }
      }
    </style>
  </body>
</html>
