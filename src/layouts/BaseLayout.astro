---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={Astro.props.description || "موقع محتوى عربي سريع ومحسّن"} />
    <link rel="canonical" href={Astro.url.href} />
    <title>{Astro.props.title || "موقعي"}</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <Header />
    <main class="container" style="margin-top: 2rem; min-height: 60vh;">
      <slot />
    </main>
    <Footer />
    <script is:inline src="/ads/ad-loader.js" defer></script>
  </body>
</html>
