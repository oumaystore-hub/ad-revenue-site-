---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title, description, image, article } = Astro.props;
const siteUrl = 'https://oumaystore-hub.github.io/ad-revenue-site';
const ogImage = image || `${siteUrl}/og-default.jpg`;

// ✅ تحديد الوضع من localStorage مباشرة في السيرفر
const isDarkMode = localStorage?.getItem('darkMode') === 'enabled' ? 'dark-mode' : '';
---

<!doctype html>
<html lang="ar" dir="rtl" class={isDarkMode}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} | TH Tech` : 'TH Tech - بوابتك التقنية'}</title>
    <meta name="description" content={description || 'TH Tech'} />
    <link rel="canonical" href={Astro.url.href} />
    <meta property="og:title" content={title || 'TH Tech'} />
    <meta property="og:description" content={description || 'TH Tech'} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&family=Inter:wght@700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-6QW7XVX75J"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-6QW7XVX75J');
    </script>
  </head>
  <body>
    <div class="reading-progress-bar" id="readingProgressBar"></div>
    <Header />
    <main><slot /></main>
    <Footer />
    <button id="backToTop" title="العودة للأعلى"><i class="fa-solid fa-arrow-up"></i></button>
    
    <script>
      // ✅ سكريبت يعمل بعد التحميل فقط
      document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.getElementById('themeToggle');
        const icon = document.getElementById('themeIcon');
        if (!toggle) return;
        // 1. تحقق من الحالة المحفوظة
        const saved = localStorage.getItem('darkMode');
        if (saved === 'enabled') {
          document.documentElement.classList.add('dark-mode');
        }

        // 2. أضف مستمع الحدث
        toggle.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark-mode');
          localStorage.setItem('darkMode', isDark ? 'enabled' : 'disabled');
          
          if (icon) {
            icon.classList.toggle('fa-moon', !isDark);
            icon.classList.toggle('fa-sun', isDark);
          }
        });
      });
    </script>

    <style>
      /* 🌙 تنسيقات الوضع النهاري */
      body, html { margin: 0; font-family: 'Cairo', sans-serif; font-size: 16px; line-height: 1.7; transition: all 0.3s ease; }
      
      /* الوضع النهاري الافتراضي */
      body { background: #f8fafc; color: #1e293b; }
      .site-header { background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); }
      
      /* 🌙 الوضع الليلي - يتم تطبيقه عبر كلاس html.dark-mode */
      html.dark-mode body {
        background: #0f172a;
        color: #f1f5f9;
      }
      html.dark-mode .site-header {
        background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
      }
      
      /* العناصر الأساسية */
      html.dark-mode .article-container,
      html.dark-mode .cat-card,
      html.dark-mode .nav-item,
      html.dark-mode .popular-posts,
      html.dark-mode .intro {
        background: #1e293b;
        color: #cbd5e1;
        border-color: #334155;
      }
      html.dark-mode h1, html.dark-mode h2, html.dark-mode h3 { color: #f1f5f9; }
      html.dark-mode p, html.dark-mode .article-meta { color: #cbd5e1; }
      html.dark-mode .ad-slot { background: #334155; border-color: #475569; }      html.dark-mode .article-content h2 { color: #60a5fa; border-right-color: #60a5fa; }
      html.dark-mode .article-badge { background: #1e40af; color: #bfdbfe; }
      html.dark-mode .back-btn { background: #334155; color: #cbd5e1; }
      html.dark-mode .back-btn:hover { background: #475569; color: #f1f5f9; }
      
      /* زر التبديل */
      .theme-toggle {
        width: 52px; height: 28px;
        background: rgba(255,255,255,0.2);
        border: 1px solid rgba(255,255,255,0.3);
        border-radius: 50px;
        cursor: pointer;
        position: relative;
        transition: all 0.3s ease;
      }
      .theme-toggle:hover { box-shadow: 0 0 12px rgba(255,255,255,0.2); }
      .toggle-thumb {
        position: absolute; top: 2px; left: 2px;
        width: 24px; height: 24px;
        background: white;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.4s cubic-bezier(0.68, -0.55, 0.27, 1.55);
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
      }
      .toggle-thumb i { font-size: 0.85rem; color: #1e3a8a; }
      
      /* حالة الدارك مود */
      html.dark-mode .theme-toggle {
        background: #334155;
        border-color: #475569;
      }
      html.dark-mode .toggle-thumb {
        left: calc(100% - 26px);
        background: #f59e0b;
        box-shadow: 0 0 15px #f59e0b;
      }
      html.dark-mode .toggle-thumb i {
        color: #1e293b;
        transform: rotate(180deg);
      }
      
      /* شريط التقدم والأزرار */
      .reading-progress-bar { position: fixed; top: 0; right: 0; height: 4px; background: linear-gradient(90deg, #3b82f6 0%, #60a5fa 100%); width: 0%; z-index: 9999; transition: width 0.1s ease; }
      #backToTop { position: fixed; bottom: 2rem; left: 2rem; background: #3b82f6; color: white; width: 45px; height: 45px; border-radius: 50%; border: none; cursor: pointer; display: none; align-items: center; justify-content: center; font-size: 1.2rem; box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4); transition: 0.3s; z-index: 999; }
      #backToTop:hover { background: #1e3a8a; transform: translateY(-3px); }
      #backToTop.visible { display: flex; }
    </style>
  </body>
</html>
