---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  { name: 'الكل', slug: '/ad-revenue-site/articles' },
  { name: 'ذكاء اصطناعي', slug: '/ad-revenue-site/category/ai' },
  { name: 'ربح رقمي', slug: '/ad-revenue-site/category/money' },
  { name: 'تقنية', slug: '/ad-revenue-site/category/tech' },
  { name: 'أداء', slug: '/ad-revenue-site/category/performance' }
];

// ✅ قائمة المقالات محدثة بالأسماء الجديدة (post-01 إلى post-10)
const articles = [
  { title: "الأمن السيبراني الشخصي في 2026", url: "/ad-revenue-site/articles/post-10", date: "2026-06-01", category: "تقنية" },
  { title: "هندسة الأوامر للمتقدمين", url: "/ad-revenue-site/articles/post-09", date: "2026-05-31", category: "ذكاء اصطناعي" },
  { title: "دليل التسويق بالعمولة", url: "/ad-revenue-site/articles/post-08", date: "2026-05-30", category: "ربح رقمي" },
  { title: "دليل تحسين محركات البحث SEO", url: "/ad-revenue-site/articles/post-07", date: "2026-05-29", category: "أداء وتقنية" },
  { title: "أفضل 5 تطبيقات للربح من الهاتف", url: "/ad-revenue-site/articles/post-06", date: "2026-05-28", category: "ربح رقمي" },
  { title: "أفضل 10 أدوات ذكاء اصطناعي مجانية", url: "/ad-revenue-site/articles/post-05", date: "2026-05-27", category: "ذكاء اصطناعي" },
  { title: "ChatGPT vs Claude AI", url: "/ad-revenue-site/articles/post-04", date: "2026-05-26", category: "ذكاء اصطناعي" },
  { title: "تحسين سرعة موقعك", url: "/ad-revenue-site/articles/post-03", date: "2026-05-25", category: "أداء وتقنية" },
  { title: "دليل المبتدئين للربح من الإنترنت", url: "/ad-revenue-site/articles/post-02", date: "2026-05-24", category: "ربح رقمي" },
  { title: "أفضل 5 اتجاهات تقنية في 2026", url: "/ad-revenue-site/articles/post-01", date: "2026-05-23", category: "تقنية" }
];
---

<BaseLayout title="المقالات - TH Tech" description="أرشيف مقالات TH Tech الشامل">
  <section class="categories-nav">
    <div class="container">
      {categories.map((cat) => (
        <a href={cat.slug} class="category-link">{cat.name}</a>
      ))}
    </div>
  </section>

  <section class="articles-hero">
    <div class="container">
      <h1>📚 المقالات</h1>
      <p>محتوى تقني عملي لمساعدتك على النجاح في العالم الرقمي</p>
      <p style="margin-top: 0.5rem; opacity: 0.8; font-size: 0.9rem;">
        إجمالي المقالات: {articles.length}
      </p>
    </div>
  </section>

  <section class="articles-list">
    <div class="container">
      {articles.map((article) => (
        <article class="article-card">
          <a href={article.url}>
            <h2>{article.title}</h2>
            <div class="article-meta">
              <span class="category">{article.category}</span>
              <time>{article.date}</time>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .categories-nav { background: #f8fafc; padding: 1.5rem 0; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .categories-nav .container { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
  .category-link { padding: 0.5rem 1.2rem; background: white; border-radius: 50px; text-decoration: none; color: #1e293b; font-weight: 600; transition: 0.3s; border: 2px solid #e2e8f0; }
  .category-link:hover { background: #3b82f6; color: white; border-color: #3b82f6; transform: translateY(-2px); }
  
  .articles-hero { text-align: center; padding: 3rem 0; background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); color: white; }
  .articles-hero h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .articles-hero p { font-size: 1.2rem; opacity: 0.9; }
  
  .articles-list { padding: 3rem 0; }
  .article-card { background: white; border-radius: 12px; padding: 2rem; margin-bottom: 2rem; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border: 1px solid #e2e8f0; transition: 0.3s; }
  .article-card:hover { transform: translateY(-5px); box-shadow: 0 8px 25px rgba(0,0,0,0.1); }
  .article-card a { text-decoration: none; color: inherit; display: block; }
  .article-card h2 { font-size: 1.4rem; color: #1e293b; margin-bottom: 0.8rem; line-height: 1.4; }
  .article-meta { display: flex; gap: 1.5rem; align-items: center; }
  .article-meta .category { background: #dbeafe; color: #1e40af; padding: 0.3rem 0.8rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600; }
  .article-meta time { color: #94a3b8; font-size: 0.9rem; }
  
  @media (max-width: 768px) {
    .articles-hero h1 { font-size: 1.8rem; }
    .article-card h2 { font-size: 1.2rem; }
  }
</style>
