---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SocialShare from '../../components/SocialShare.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import TableOfContents from '../../components/TableOfContents.astro';

const headings = [
  { slug: 'heading-1', text: '1. التهديدات الجديدة', depth: 2 },
  { slug: 'heading-2', text: '2. المصادقة متعددة العوامل', depth: 2 },
  { slug: 'heading-3', text: '3. إدارة كلمات المرور', depth: 2 },
  { slug: 'heading-4', text: '4. الخصوصية الرقمية', depth: 2 },
  { slug: 'heading-5', text: '5. النسخ الاحتياطي', depth: 2 }
];

const pageTitle = "الأمن السيبراني الشخصي في 2026: حماية نفسك من تهديدات الذكاء الاصطناعي";
const description = "تعلم كيف تحمي بياناتك وحساباتك من هجمات التصيد الذكي واستنساخ الهوية.";
const publishDate = "2026-06-01";
const articleImage = "https://images.unsplash.com/photo-1550751827-4bd374c3f58b?w=1200&q=80";
const category = "تقنية";
const categorySlug = "tech";
---

<BaseLayout title={pageTitle} description={description} image={articleImage} article={{ publishedTime: publishDate, modifiedTime: publishDate, author: "TH Tech", category, categorySlug }}>
  <div class="article-wrapper">
    <main class="article-main">
      <article class="article-container">
        <div class="article-hero-image"><img src={articleImage} alt={pageTitle} loading="lazy" /></div>
        <header class="article-header">
          <span class="article-badge" style="background:#dbeafe; color:#1e40af; padding:0.3rem 1rem; border-radius:50px; font-size:0.85rem; font-weight:600;">{category}</span>
          <h1>{pageTitle}</h1>
          <div class="article-meta"><span>📅 {publishDate}</span></div>
        </header>
        <div class="ad-slot"><p style="color:#999; text-align:center; padding:10px; background:#f9f9f9; border:1px dashed #ccc;">مساحة إعلانية</p></div>
        
        <div class="article-content">
          <p class="intro">في 2026، لم يعد الهاكرز شخصاً وحيداً. إنها أنظمة ذكاء اصطناعي تعمل تلقائياً. الحماية القديمة لم تعد كافية.</p>
          
          <h2 id="heading-1">1. التهديدات الجديدة التي يجب أن تعرفها</h2>
          <p>التصيد الذكي، استنساخ الصوت والفيديو، وهجمات كلمات المرور الذكية أصبحت تهديدات يومية تتطلب وعياً تقنياً عالياً.</p>
          
          <h2 id="heading-2">2. خط الدفاع الأول: المصادقة متعددة العوامل (MFA)</h2>
          <p>فعّل MFA على كل حساباتك. تجنب SMS واستخدم تطبيقات المصادقة أو مفاتيح الأمان الفيزيائية.</p>
          
          <div class="ad-slot"><p style="color:#999; text-align:center; padding:10px; background:#f9f9f9; border:1px dashed #ccc;">مساحة إعلانية</p></div>
          
          <h2 id="heading-3">3. إدارة كلمات المرور</h2>
          <p>استخدم مدير كلمات مرور موثوق لإنشاء كلمات فريدة ومعقدة لكل موقع. عقلك ليس خزنة آمنة.</p>
          
          <h2 id="heading-4">4. الخصوصية الرقمية وتقليل البصمة</h2>
          <p>راجع إعدادات الخصوصية، احذف الحسابات القديمة، واستخدم بريداً بديلاً للتسجيل في المواقع غير المهمة.</p>
          
          <h2 id="heading-5">5. النسخ الاحتياطي: خط الدفاع الأخير</h2>
          <p>اتبع قاعدة 3-2-1 للنسخ الاحتياطي. النسخ الذي لا يمكنك استعادته لا قيمة له.</p>
        </div>

        <div class="ad-slot"><p style="color:#999; text-align:center; padding:10px; background:#f9f9f9; border:1px dashed #ccc;">مساحة إعلانية</p></div>
        <SocialShare title={pageTitle} url="https://oumaystore-hub.github.io/ad-revenue-site/articles/post-10" />
        <RelatedArticles currentSlug={categorySlug} currentCategory={category} />
        <div class="article-footer-actions">
          <a href="/ad-revenue-site/articles" class="back-btn">↩️ العودة للمقالات</a>
          <a href="/ad-revenue-site/category/tech" class="back-btn" style="margin-right:10px;">📂 المزيد</a>
        </div>
      </article>
    </main>
    <aside class="article-sidebar"><TableOfContents headings={headings} /></aside>
  </div>
</BaseLayout>

<style>
  .article-container { max-width: 100%; margin: 0; padding: 2.5rem; background: white; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); line-height: 1.5; }
  .article-hero-image { margin: -2.5rem -2.5rem 2rem -2.5rem; border-radius: 12px 12px 0 0; overflow: hidden; height: 400px; }
  .article-hero-image img { width: 100%; height: 100%; object-fit: cover; }
  .article-header { border-bottom: 2px solid #f0f0f0; padding-bottom: 1.5rem; margin-bottom: 2rem; }
  .article-badge { display: inline-block; margin-bottom: 1rem; }
  .article-header h1 { font-size: 2rem; color: #1e293b; margin-bottom: 1rem; }
  .article-meta { color: #64748b; font-size: 0.85rem; display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .article-content h2 { color: #1e40af; margin-top: 2.5rem; margin-bottom: 0.8rem; font-size: 1.4rem; border-right: 4px solid #1e40af; padding-right: 0.8rem; }
  .intro { background: #eff6ff; padding: 1.2rem; border-right: 4px solid #1e40af; border-radius: 6px; margin-bottom: 2.5rem; font-size: 1.1rem; color: #475569; }
  .ad-slot { margin: 2rem 0; padding: 1rem; background: #f8fafc; border-radius: 8px; border: 1px dashed #cbd5e1; text-align: center; }
  .article-footer-actions { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #e2e8f0; text-align: center; }
  .back-btn { display: inline-block; padding: 0.8rem 1.5rem; background: #e2e8f0; color: #475569; border-radius: 8px; text-decoration: none; font-weight: 600; transition: all 0.3s; margin: 0.5rem; }
  .back-btn:hover { background: #cbd5e1; color: #1e293b; }
  @media (max-width: 1024px) { .article-container { padding: 1.5rem; } .article-hero-image { margin: -1.5rem -1.5rem 1.5rem -1.5rem; height: 220px; } .article-header h1 { font-size: 1.6rem; } }
</style>
