---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SocialShare from '../../components/SocialShare.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import AuthorBio from '../../components/AuthorBio.astro';

const pageTitle = "أفضل 5 اتجاهات تقنية ستغيّر العالم في 2026";
const description = "اكتشف أهم 5 تقنيات ستغير المستقبل: الذكاء الاصطناعي التوليدي، التجارة الذكية، الأمن السيبراني، والحوسبة السحابية.";
const publishDate = "2026-05-23";
const articleImage = "https://images.unsplash.com/photo-1485827404703-89b55fcc595e?w=1200&q=80";
const category = "تقنية";
const categorySlug = "tech";

// ✅ استخراج العناوين
const headings = (await Astro.glob('./post-*.astro'))
  .filter(p => p.url.includes('post-1'))
  .map(p => ({ slug: '1-الذكاء-الاصطناعي-التوليدي', text: '1. الذكاء الاصطناعي التوليدي', depth: 2 }))
  .concat([
    { slug: '2-التجارة-الإلكترونية-الذكية', text: '2. التجارة الإلكترونية الذكية', depth: 2 },
    { slug: '3-الأمن-السيبراني-كضرورة', text: '3. الأمن السيبراني كضرورة', depth: 2 },
    { slug: '4-الحوسبة-السحابية-الهجينة', text: '4. الحوسبة السحابية الهجينة', depth: 2 },
    { slug: '5-الأجهزة-القابلة-للطي', text: '5. الأجهزة القابلة للطي', depth: 2 }
  ]);
---

<BaseLayout title={pageTitle} description={description} image={articleImage} article={{ publishedTime: publishDate, modifiedTime: publishDate, author: "TH Tech", category, categorySlug }}>
  <div class="article-wrapper">
    <main class="article-main">
      <article class="article-container">
        <div class="article-hero-image"><img src={articleImage} alt={pageTitle} loading="lazy" /></div>
        <header class="article-header">
          <span class="article-badge" style="background:#dbeafe; color:#1e40af; padding:0.3rem 1rem; border-radius:50px; font-size:0.85rem; font-weight:600;">{category}</span>
          <h1>{pageTitle}</h1>
          <div class="article-meta"><span>📅 {publishDate}</span></div>
        </header>
        <div class="ad-slot"><p style="color:#999; text-align:center; padding:10px; background:#f9f9f9; border:1px dashed #ccc;">مساحة إعلانية</p></div>
        <div class="article-content">
          <p class="intro">يشهد عالم التكنولوجيا تطورًا متسارعًا لم نشهد مثله من قبل. ومع دخول سنة 2026، لم تعد التقنية رفاهية، بل أصبحت العمود الفقري للأعمال والتعليم.</p>
          <h2 id="1-الذكاء-الاصطناعي-التوليدي">1. الذكاء الاصطناعي التوليدي (Generative AI)</h2>
          <p>لم يعد مقتصرًا على الأبحاث الأكاديمية. اليوم، تُستخدم نماذج الذكاء الاصطناعي في كتابة الأكواد، التصميم، وتحليل البيانات الضخمة.</p>
          <h2 id="2-التجارة-الإلكترونية-الذكية">2. التجارة الإلكترونية الذكية</h2>
          <p>المتاجر التقليدية تتحول إلى منصات ذكية تستخدم خوارزميات التعلم الآلي لتحليل سلوك الزائر واقتراح المنتجات بدقة.</p>
          <div class="ad-slot"><p style="color:#999; text-align:center; padding:10px; background:#f9f9f9; border:1px dashed #ccc;">مساحة إعلانية</p></div>
          <h2 id="3-الأمن-السيبراني-كضرورة">3. الأمن السيبراني كضرورة</h2>
          <p>مع تزايد الهجمات الإلكترونية، أصبح تأمين البنية الرقمية أولوية قصوى للشركات والأفراد.</p>
          <h2 id="4-الحوسبة-السحابية-الهجينة">4. الحوسبة السحابية الهجينة</h2>
          <p>النموذج الهجين يجمع بين الأمان المحلي ومرونة السحابة العامة، مما يضمن استمرارية العمل وتقليل التكاليف.</p>
          <h2 id="5-الأجهزة-القابلة-للطي">5. الأجهزة القابلة للطي</h2>
          <p>أصبحت واقعًا ملموسًا، مما يفتح آفاقًا جديدة للمصممين والمبرمجين.</p>
        </div>
        <div class="ad-slot"><p style="color:#999; text-align:center; padding:10px; background:#f9f9f9; border:1px dashed #ccc;">مساحة إعلانية</p></div>
        <SocialShare title={pageTitle} url="https://oumaystore-hub.github.io/ad-revenue-site/articles/post-1" />
        <AuthorBio author={{ name: "TH Tech Team", role: "فريق TH Tech", bio: "فريق من الخبراء المتخصصين في التكنولوجيا، الذكاء الاصطناعي، والربح الرقمي.", avatar: "https://ui-avatars.com/api/?name=TH+Tech&background=3b82f6&color=fff&size=128", social: { twitter: "https://twitter.com/thtech", email: "contact@thtech.com" } }} />
        <RelatedArticles currentSlug={categorySlug} currentCategory={category} />
        <div class="article-footer-actions">
          <a href="/ad-revenue-site/articles" class="back-btn">↩️ العودة للمقالات</a>
          <a href="/ad-revenue-site/category/tech" class="back-btn" style="margin-right:10px;">📂 المزيد من قسم {category}</a>
        </div>
      </article>
    </main>
    <aside class="article-sidebar"><TableOfContents headings={headings} /></aside>
  </div>
</BaseLayout>

<style>
  .article-container { max-width: 100%; margin: 0; padding: 2.5rem; background: white; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); line-height: 1.85; }
  .article-hero-image { margin: -2.5rem -2.5rem 2rem -2.5rem; border-radius: 12px 12px 0 0; overflow: hidden; height: 400px; }
  .article-hero-image img { width: 100%; height: 100%; object-fit: cover; }
  .article-header { border-bottom: 2px solid #f0f0f0; padding-bottom: 1.5rem; margin-bottom: 2rem; }
  .article-badge { display: inline-block; margin-bottom: 1rem; }
  .article-header h1 { font-size: 2.2rem; color: #1e293b; margin-bottom: 1rem; }
  .article-meta { color: #64748b; font-size: 0.9rem; display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .article-content h2 { color: #3b82f6; margin-top: 2.5rem; margin-bottom: 1rem; font-size: 1.6rem; border-right: 4px solid #3b82f6; padding-right: 0.8rem; }
  .intro { background: #eff6ff; padding: 1.2rem; border-right: 4px solid #3b82f6; border-radius: 6px; margin-bottom: 2.5rem; font-size: 1.2rem; color: #475569; }
  .ad-slot { margin: 2rem 0; padding: 1rem; background: #f8fafc; border-radius: 8px; border: 1px dashed #cbd5e1; text-align: center; }
  .article-footer-actions { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #e2e8f0; text-align: center; }
  .back-btn { display: inline-block; padding: 0.8rem 1.5rem; background: #e2e8f0; color: #475569; border-radius: 8px; text-decoration: none; font-weight: 600; transition: all 0.3s; margin: 0.5rem; }
  .back-btn:hover { background: #cbd5e1; color: #1e293b; }
  @media (max-width: 1024px) { .article-container { padding: 1.5rem; } .article-hero-image { margin: -1.5rem -1.5rem 1.5rem -1.5rem; height: 220px; } .article-header h1 { font-size: 1.7rem; } }
</style>
