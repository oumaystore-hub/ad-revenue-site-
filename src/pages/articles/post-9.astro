---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SocialShare from '../../components/SocialShare.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import TableOfContents from '../../components/TableOfContents.astro';

const headings = [
  { slug: 'heading-1', text: '1. لماذا تفشل معظم الأوامر؟', depth: 2 },
  { slug: 'heading-2', text: '2. تقنية Chain-of-Thought', depth: 2 },
  { slug: 'heading-3', text: '3. Few-Shot Prompting', depth: 2 },
  { slug: 'heading-4', text: '4. تعيين الأدوار والشخصيات', depth: 2 },
  { slug: 'heading-5', text: '5. التحكم في المخرجات', depth: 2 }
];

const pageTitle = "هندسة الأوامر للمتقدمين: كيف تستخرج أقصى قدرات نماذج اللغة الكبيرة";
const description = "تعلم تقنيات Chain-of-Thought وFew-Shot Prompting لتحقيق نتائج احترافية.";
const publishDate = "2026-05-31";
const articleImage = "https://images.unsplash.com/photo-1620712943543-bcc4688e7485?w=1200&q=80";
const category = "ذكاء اصطناعي";
const categorySlug = "ai";
---

<BaseLayout title={pageTitle} description={description} image={articleImage} article={{ publishedTime: publishDate, modifiedTime: publishDate, author: "TH Tech", category, categorySlug }}>
  <div class="article-wrapper">
    <main class="article-main">
      <article class="article-container">
        <div class="article-hero-image"><img src={articleImage} alt={pageTitle} loading="lazy" /></div>
        <header class="article-header">
          <span class="article-badge" style="background:#e0e7ff; color:#3730a3; padding:0.3rem 1rem; border-radius:50px; font-size:0.85rem; font-weight:600;">{category}</span>
          <h1>{pageTitle}</h1>
          <div class="article-meta"><span>📅 {publishDate}</span></div>
        </header>
        <div class="ad-slot"><p style="color:#999; text-align:center; padding:10px; background:#f9f9f9; border:1px dashed #ccc;">مساحة إعلانية</p></div>
        
        <div class="article-content">
          <p class="intro">معظم المستخدمين يتوقفون عند الأوامر البسيطة. لكن المحترفين يعرفون أن الفرق بين نتيجة عادية واستثنائية يكمن في هندسة الأوامر.</p>
          
          <h2 id="heading-1">1. لماذا تفشل معظم الأوامر؟</h2>
          <p>النماذج اللغوية ليست بشرًا. عندما تعطي أمراً غامضاً، فإنها تخمن نيتك. الحل هو السياق المحدد والقيود الواضحة.</p>
          
          <h2 id="heading-2">2. تقنية Chain-of-Thought (CoT)</h2>
          <p>اطلب من النموذج أن يفكر خطوة بخطوة. هذه التقنية تحسن دقة الاستنتاج المنطقي والرياضي بنسبة كبيرة.</p>
          
          <div class="ad-slot"><p style="color:#999; text-align:center; padding:10px; background:#f9f9f9; border:1px dashed #ccc;">مساحة إعلانية</p></div>
          
          <h2 id="heading-3">3. Few-Shot Prompting: علّم بالمثال</h2>
          <p>النماذج تتعلم بشكل أفضل من الأمثلة. أعطِ 2-3 أمثلة على المدخلات والمخرجات المتوقعة لضمان الاتساق.</p>
          
          <h2 id="heading-4">4. تعيين الأدوار والشخصيات</h2>
          <p>عندما تحدد دوراً دقيقاً للنموذج، فإنك تغير مصدر المعرفة الذي يستند إليه للحصول على إجابات متخصصة.</p>
          
          <h2 id="heading-5">5. التحكم في المخرجات والقيود</h2>
          <p>حدد الطول، النبرة، التنسيق، والقيود السلبية بدقة لضمان الحصول على النتيجة المطلوبة تماماً.</p>
        </div>

        <div class="ad-slot"><p style="color:#999; text-align:center; padding:10px; background:#f9f9f9; border:1px dashed #ccc;">مساحة إعلانية</p></div>
        <SocialShare title={pageTitle} url="https://oumaystore-hub.github.io/ad-revenue-site/articles/post-9" />
        <RelatedArticles currentSlug={categorySlug} currentCategory={category} />
        <div class="article-footer-actions">
          <a href="/ad-revenue-site/articles" class="back-btn">↩️ العودة للمقالات</a>
          <a href="/ad-revenue-site/category/ai" class="back-btn" style="margin-right:10px;">📂 المزيد</a>
        </div>
      </article>
    </main>
    <aside class="article-sidebar"><TableOfContents headings={headings} /></aside>
  </div>
</BaseLayout>

<style>
  .article-container { max-width: 100%; margin: 0; padding: 2.5rem; background: white; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); line-height: 1.5; }
  .article-hero-image { margin: -2.5rem -2.5rem 2rem -2.5rem; border-radius: 12px 12px 0 0; overflow: hidden; height: 400px; }
  .article-hero-image img { width: 100%; height: 100%; object-fit: cover; }
  .article-header { border-bottom: 2px solid #f0f0f0; padding-bottom: 1.5rem; margin-bottom: 2rem; }
  .article-badge { display: inline-block; margin-bottom: 1rem; }
  .article-header h1 { font-size: 2rem; color: #1e293b; margin-bottom: 1rem; }
  .article-meta { color: #64748b; font-size: 0.85rem; display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .article-content h2 { color: #3730a3; margin-top: 2.5rem; margin-bottom: 0.8rem; font-size: 1.4rem; border-right: 4px solid #3730a3; padding-right: 0.8rem; }
  .intro { background: #e0e7ff; padding: 1.2rem; border-right: 4px solid #3730a3; border-radius: 6px; margin-bottom: 2.5rem; font-size: 1.1rem; color: #475569; }
  .ad-slot { margin: 2rem 0; padding: 1rem; background: #f8fafc; border-radius: 8px; border: 1px dashed #cbd5e1; text-align: center; }
  .article-footer-actions { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #e2e8f0; text-align: center; }
  .back-btn { display: inline-block; padding: 0.8rem 1.5rem; background: #e2e8f0; color: #475569; border-radius: 8px; text-decoration: none; font-weight: 600; transition: all 0.3s; margin: 0.5rem; }
  .back-btn:hover { background: #cbd5e1; color: #1e293b; }
  @media (max-width: 1024px) { .article-container { padding: 1.5rem; } .article-hero-image { margin: -1.5rem -1.5rem 1.5rem -1.5rem; height: 220px; } .article-header h1 { font-size: 1.6rem; } }
</style>
