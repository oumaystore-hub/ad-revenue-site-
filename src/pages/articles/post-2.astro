---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SocialShare from '../../components/SocialShare.astro';

// 📝 بيانات المقال
const pageTitle = "دليل المبتدئين الشامل: كيف تبدأ ربحًا حقيقيًا من الإنترنت";
const description = "خطوات عملية ومجربة لبدء مشروعك الرقمي الأول، من اختيار المجال إلى تحقيق الدخل الأول عبر الإعلانات والتسويق بالعمولة.";
const publishDate = "2026-05-24";
const articleImage = "https://images.unsplash.com/photo-1553877522-43269d4ea984?w=1200&q=80";

// ️ تعريف التصنيف
const category = "ربح رقمي";
const categorySlug = "money";
---

<BaseLayout 
  title={pageTitle} 
  description={description}
  image={articleImage}
  article={{
    publishedTime: publishDate,
    modifiedTime: publishDate,
    author: "TH Tech",
    category: category,
    categorySlug: categorySlug
  }}
>

  <article class="article-container">
    <div class="article-hero-image">
      <img src={articleImage} alt={pageTitle} loading="lazy" />
    </div>

    <header class="article-header">
      <span class="article-badge" style="background:#dcfce7; color:#166534; padding:0.3rem 1rem; border-radius:50px; font-size:0.85rem; font-weight:600;">{category}</span>
      <h1>{pageTitle}</h1>
      <div class="article-meta">
        <span>📅 {publishDate}</span>
        <span>️ وقت القراءة: 7 دقائق</span>
      </div>
    </header>

    <div class="ad-slot">
      <p style="color:#999; text-align:center; padding:10px; background:#f9f9f9; border:1px dashed #ccc;">مساحة إعلانية (Top Banner)</p>
    </div>

    <div class="article-content">
      <p class="intro">
        الربح من الإنترنت لم يعد حلمًا بعيدًا. الفرق بين من ينجح ومن يفشل يكمن في <strong>المنهجية الصحيحة</strong>. في هذا الدليل، سنأخذك خطوة بخطوة من الصفر حتى تحقيق أول دخل رقمي.
      </p>
      <h2>1. اختر مجالًا يجمع بين الشغف والربحية</h2>
      <p>لا تختر مجالًا لمجرد أنه رائجة، بل اختر ما تعرفه. مجالات عالية الربح: التقنية، التمويل الشخصي، الصحة.</p>

      <h2>2. ابنِ أساسك التقني بشكل صحيح</h2>
      <p>نطاق خاص يعطي مصداقية، واستضافة سريعة عامل ترتيب أساسي.</p>

      <div class="ad-slot">
        <p style="color:#999; text-align:center; padding:10px; background:#f9f9f9; border:1px dashed #ccc;">مساحة إعلانية (In-Article)</p>
      </div>

      <h2>3. المحتوى هو الملك</h2>
      <p>المحتوى المفيد والمهيكّل لمحركات البحث هو مفتاح الجذب المستمر.</p>

      <h2>4. فعّل قنوات الربح</h2>
      <ul>
        <li>📺 <strong>إعلانات AdSense:</strong> ممتازة للمبتدئين.</li>
        <li> <strong>التسويق بالعمولة:</strong> ربح أعلى.</li>
        <li>📘 <strong>المنتجات الرقمية:</strong> كتب ودورات.</li>
      </ul>

      <h2>🚀 الخلاصة</h2>
      <p>ابدأ اليوم بمقال واحد، حسّنه، انشره، وكرر العملية. خلال 3-6 أشهر ستلاحظ النتائج.</p>
    </div>

    <SocialShare title={pageTitle} url="https://oumaystore-hub.github.io/ad-revenue-site/articles/post-2" />

    <div class="article-footer-actions">
      <a href="/ad-revenue-site/articles" class="back-btn">↩️ العودة للمقالات</a>
      <a href="/ad-revenue-site/category/money" class="back-btn" style="margin-right:10px;">📂 المزيد من قسم {category}</a>
    </div>

  </article>
</BaseLayout>

<style>
  .article-container { max-width: 800px; margin: 2rem auto; background: white; padding: 2.5rem; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); line-height: 1.85; }
  .article-hero-image { margin: -2.5rem -2.5rem 2rem -2.5rem; border-radius: 12px 12px 0 0; overflow: hidden; height: 400px; }
  .article-hero-image img { width: 100%; height: 100%; object-fit: cover; }
  .article-header { border-bottom: 2px solid #f0f0f0; padding-bottom: 1.5rem; margin-bottom: 2rem; }
  .article-badge { display: inline-block; margin-bottom: 1rem; }
  .article-header h1 { font-size: 2.2rem; color: #1e293b; margin-bottom: 1rem; }
  .article-meta { color: #64748b; font-size: 0.9rem; display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .article-content h2 { color: #166534; margin-top: 2.5rem; margin-bottom: 1rem; font-size: 1.6rem; border-right: 4px solid #166534; padding-right: 0.8rem; }
  .intro { background: #f0fdf4; padding: 1.2rem; border-right: 4px solid #166534; border-radius: 6px; margin-bottom: 2.5rem; font-size: 1.2rem; color: #475569; }
  .ad-slot { margin: 2rem 0; padding: 1rem; background: #f8fafc; border-radius: 8px; border: 1px dashed #cbd5e1; text-align: center; }
  .article-footer-actions { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #e2e8f0; text-align: center; }
  .back-btn { display: inline-block; padding: 0.8rem 1.5rem; background: #e2e8f0; color: #475569; border-radius: 8px; text-decoration: none; font-weight: 600; transition: all 0.3s; margin: 0.5rem; }
  .back-btn:hover { background: #cbd5e1; color: #1e293b; }
  @media (max-width: 768px) { .article-container { padding: 1.5rem; margin: 1rem; } .article-hero-image { margin: -1.5rem -1.5rem 1.5rem -1.5rem; height: 220px; } .article-header h1 { font-size: 1.7rem; } }</style>
