---
import BaseLayout from '../layouts/BaseLayout.astro';

// جلب آخر 3 مقالات
const modules = import.meta.glob('./articles/post-*.astro', { eager: true });
const allPosts = Object.values(modules).map((module: any) => ({
  url: module.url || '',
  frontmatter: module.frontmatter || {}
}));

const recentArticles = allPosts
  .filter(post => post.frontmatter && post.frontmatter.pageTitle)
  .sort((a: any, b: any) => {
    const numA = parseInt(a.url.match(/post-(\d+)/)?.[1] || '0');
    const numB = parseInt(b.url.match(/post-(\d+)/)?.[1] || '0');
    return numB - numA;
  })
  .slice(0, 3);

const features = [
  {
    icon: '🎯',
    title: 'محتوى عملي',
    description: 'مقالات ودروس تطبيقية تركز على النتائج العملية والاستراتيجيات المجرّبة'
  },
  {
    icon: '⚡',
    title: 'معلومات محدثة',
    description: 'نتابع أحدث التقنيات والاتجاهات لنقدم لك معلومات دقيقة وحديثة'
  },
  {
    icon: '💡',
    title: 'خبرات متخصصة',
    description: 'فريق من الخبراء المتخصصين في التكنولوجيا والذكاء الاصطناعي والربح الرقمي'
  },
  {
    icon: '🚀',
    title: 'نمو مستمر',
    description: 'نساعدك على تطوير مهاراتك وتحقيق أهدافك في العالم الرقمي'
  }
];

const stats = [
  { number: '10+', label: 'مقال تقني' },
  { number: '4', label: 'أقسام متخصصة' },
  { number: '24/7', label: 'متاح للجميع' },
  { number: '100%', label: 'محتوى مجاني' }
];
---
<BaseLayout title="TH Tech - بوابتك التقنية للذكاء الاصطناعي والربح الرقمي" description="اكتشف أحدث التقنيات، الذكاء الاصطناعي، واستراتيجيات الربح الرقمي مع TH Tech">
  
  <!-- ✅ Hero Section -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-particles">
        <div class="particle" style="--i: 0"></div>
        <div class="particle" style="--i: 1"></div>
        <div class="particle" style="--i: 2"></div>
        <div class="particle" style="--i: 3"></div>
        <div class="particle" style="--i: 4"></div>
      </div>
    </div>
    
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge">
          <span class="pulse"></span>
          مرحباً بك في TH Tech
        </div>
        <h1 class="hero-title">
          بوابتك إلى عالم
          <span class="gradient-text">التقنية والابتكار</span>
        </h1>
        <p class="hero-subtitle">
          نقدم لك محتوى تقني متخصص في الذكاء الاصطناعي، الربح الرقمي، 
          وتطوير المواقع لتبقى في صدارة المجال
        </p>
        <div class="hero-cta">
          <a href="/ad-revenue-site/articles" class="btn btn-primary btn-lg">
            <span>📚</span>
            استكشف المقالات
          </a>
          <a href="#about" class="btn btn-outline btn-lg">
            <span>ℹ️</span>
            اعرف المزيد
          </a>
        </div>
      </div>
      
      <div class="hero-image">
        <div class="floating-card card-1">
          <span class="icon">🤖</span>
          <span class="text">ذكاء اصطناعي</span>
        </div>
        <div class="floating-card card-2">
          <span class="icon">💰</span>
          <span class="text">ربح رقمي</span>
        </div>
        <div class="floating-card card-3">          <span class="icon"></span>
          <span class="text">أداء عالي</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ✅ Stats Section -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        {stats.map((stat) => (
          <div class="stat-card">
            <div class="stat-number">{stat.number}</div>
            <div class="stat-label">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ✅ About Section -->
  <section id="about" class="about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-content">
          <h2 class="section-title">
            <span class="title-icon">🎯</span>
            من نحن؟
          </h2>
          <p class="about-text">
            <strong>TH Tech</strong> هي بوابتك الشاملة لعالم التكنولوجيا والابتكار. 
            نؤمن بأن المعرفة هي القوة، لذا نعمل على تقديم محتوى عربي عالي الجودة 
            يغطي أحدث التطورات في مجالات الذكاء الاصطناعي، الربح الرقمي، 
            وتطوير المواقع الإلكترونية.
          </p>
          <p class="about-text">
            هدفنا تمكينك من مواكبة العصر الرقمي من خلال مقالات عملية، 
            شروحات مفصلة، ونصائح مجرّبة تساعدك على النجاح في عالم التكنولوجيا.
          </p>
          
          <div class="about-features">
            {features.map((feature) => (
              <div class="feature-item">
                <span class="feature-icon">{feature.icon}</span>
                <div class="feature-text">
                  <h4>{feature.title}</h4>
                  <p>{feature.description}</p>
                </div>
              </div>            ))}
          </div>
        </div>
        
        <div class="about-image">
          <div class="image-wrapper">
            <img src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=800&q=80" alt="Technology" class="main-img" />
            <div class="image-overlay"></div>
          </div>
          <div class="experience-badge">
            <span class="exp-number">2026</span>
            <span class="exp-text">مستقبل التقنية</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ✅ Recent Articles -->
  {recentArticles.length > 0 && (
    <section class="articles-section">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">
            <span>📝</span>
            أحدث المقالات
          </h2>
          <a href="/ad-revenue-site/articles" class="view-all-link">عرض الكل ←</a>
        </div>
        
        <div class="articles-grid">
          {recentArticles.map((post: any) => {
            const { pageTitle, description, publishDate, articleImage, category } = post.frontmatter;
            return (
              <article class="article-card">
                <a href={post.url}>
                  <div class="article-image">
                    <img src={articleImage} alt={pageTitle} loading="lazy" />
                    <span class="article-category">{category}</span>
                  </div>
                  <div class="article-content">
                    <h3>{pageTitle}</h3>
                    <p>{description}</p>
                    <div class="article-meta">
                      <time>📅 {publishDate}</time>
                      <span class="read-time">5 دقائق قراءة</span>
                    </div>
                  </div>
                </a>
              </article>            );
          })}
        </div>
        
        <div class="text-center">
          <a href="/ad-revenue-site/articles" class="btn btn-primary">عرض جميع المقالات 📖</a>
        </div>
      </div>
    </section>
  )}

  <!-- ✅ CTA Section -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>🚀 ابدأ رحلتك التقنية الآن</h2>
        <p>انضم إلى مجتمع TH Tech واكتشف عالماً من المعرفة والفرص</p>
        <a href="/ad-revenue-site/articles" class="btn btn-white btn-lg">تصفح المقالات مجاناً</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  :root {
    --primary: #3b82f6;
    --primary-dark: #1e40af;
    --secondary: #64748b;
    --accent: #8b5cf6;
    --success: #10b981;
    --bg: #f8fafc;
    --card: #ffffff;
    --text: #1e293b;
    --text-light: #64748b;
    --border: #e2e8f0;
    --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    --shadow-lg: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
  }

  * { box-sizing: border-box; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
  
  /* ✅ Hero Section */
  .hero {
    position: relative;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 6rem 0 5rem;
    overflow: hidden;    min-height: 700px;
    display: flex;
    align-items: center;
  }
  .hero-bg { position: absolute; inset: 0; overflow: hidden; }
  .hero-particles { position: absolute; inset: 0; }
  .particle {
    position: absolute;
    width: 10px; height: 10px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    animation: float 20s infinite ease-in-out;
    animation-delay: calc(var(--i) * 2s);
  }
  .particle:nth-child(1) { top: 20%; left: 10%; }
  .particle:nth-child(2) { top: 60%; left: 80%; }
  .particle:nth-child(3) { top: 40%; left: 90%; }
  .particle:nth-child(4) { top: 80%; left: 20%; }
  .particle:nth-child(5) { top: 10%; left: 70%; }
  
  @keyframes float {
    0%, 100% { transform: translateY(0) translateX(0); }
    33% { transform: translateY(-30px) translateX(20px); }
    66% { transform: translateY(20px) translateX(-20px); }
  }

  .hero .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.2);
    padding: 0.5rem 1.2rem;
    border-radius: 50px;
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.3);
  }
  .pulse {
    width: 8px; height: 8px;
    background: #10b981;    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }
  
  .hero-title {
    font-size: 3.2rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    font-family: 'Tajawal', sans-serif;
  }
  .gradient-text {
    background: linear-gradient(135deg, #fff 0%, #a5b4fc 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-subtitle {
    font-size: 1.25rem;
    line-height: 1.8;
    margin-bottom: 2.5rem;
    opacity: 0.95;
    font-family: 'Tajawal', sans-serif;
  }
  
  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }
  
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1rem 2rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1rem;
    transition: all 0.3s;
    font-family: 'Tajawal', sans-serif;
    border: 2px solid transparent;
    cursor: pointer;
  }
  .btn-lg { padding: 1.2rem 2.5rem; font-size: 1.1rem; }
  .btn-primary {
    background: white;
    color: #667eea;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);  }
  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.3);
  }
  .btn-outline {
    background: rgba(255,255,255,0.1);
    color: white;
    border-color: rgba(255,255,255,0.5);
    backdrop-filter: blur(10px);
  }
  .btn-outline:hover {
    background: rgba(255,255,255,0.2);
    transform: translateY(-3px);
  }
  .btn-white {
    background: white;
    color: #667eea;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
  }
  .btn-white:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.3);
  }

  .hero-image { position: relative; height: 500px; }
  .floating-card {
    position: absolute;
    background: white;
    color: #1e293b;
    padding: 1.2rem 1.8rem;
    border-radius: 16px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-weight: 700;
    animation: floatCard 6s infinite ease-in-out;
    backdrop-filter: blur(10px);
  }
  .floating-card .icon { font-size: 2rem; }
  .card-1 { top: 10%; left: 10%; animation-delay: 0s; }
  .card-2 { top: 50%; right: 10%; animation-delay: 2s; }
  .card-3 { bottom: 10%; left: 20%; animation-delay: 4s; }
  
  @keyframes floatCard {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
  /* ✅ Stats Section */
  .stats-section {
    background: white;
    padding: 3rem 0;
    margin-top: -3rem;
    position: relative;
    z-index: 10;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }
  .stat-card {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 2rem;
    border-radius: 16px;
    text-align: center;
    box-shadow: var(--shadow-lg);
    transition: transform 0.3s;
  }
  .stat-card:hover { transform: translateY(-5px); }
  .stat-number { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; }
  .stat-label { font-size: 1rem; opacity: 0.9; font-family: 'Tajawal', sans-serif; }

  /* ✅ About Section */
  .about-section { padding: 6rem 0; background: var(--bg); }
  .about-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 2rem;
    color: var(--text);
    font-family: 'Tajawal', sans-serif;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .title-icon { font-size: 2.8rem; }
  
  .about-text {
    font-size: 1.1rem;
    line-height: 2;
    color: var(--text-light);    margin-bottom: 1.5rem;
    font-family: 'Tajawal', sans-serif;
  }
  .about-text strong { color: var(--text); }
  
  .about-features { margin-top: 2.5rem; display: grid; gap: 1.5rem; }
  .feature-item { display: flex; gap: 1rem; align-items: flex-start; }
  .feature-icon { font-size: 2rem; flex-shrink: 0; }
  .feature-text h4 {
    font-size: 1.1rem;
    color: var(--text);
    margin-bottom: 0.3rem;
    font-family: 'Tajawal', sans-serif;
    font-weight: 700;
  }
  .feature-text p {
    font-size: 0.95rem;
    color: var(--text-light);
    line-height: 1.6;
    font-family: 'Tajawal', sans-serif;
  }

  .about-image { position: relative; }
  .image-wrapper {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .main-img { width: 100%; height: auto; display: block; }
  .image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.3) 0%, rgba(118, 75, 162, 0.3) 100%);
  }
  .experience-badge {
    position: absolute;
    bottom: -20px;
    left: -20px;
    background: white;
    padding: 1.5rem 2rem;
    border-radius: 16px;
    box-shadow: var(--shadow-lg);
    text-align: center;
  }
  .exp-number { display: block; font-size: 2rem; font-weight: 800; color: #667eea; }
  .exp-text { font-size: 0.9rem; color: var(--text-light); font-family: 'Tajawal', sans-serif; }

  /* ✅ Articles Section */
  .articles-section { padding: 6rem 0; background: var(--bg); }  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 3rem;
  }
  .view-all-link {
    color: var(--primary);
    text-decoration: none;
    font-weight: 700;
    font-size: 1.1rem;
    font-family: 'Tajawal', sans-serif;
    transition: transform 0.3s;
  }
  .view-all-link:hover { transform: translateX(-5px); }
  
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }
  .article-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: all 0.3s;
  }
  .article-card:hover {
    transform: translateY(-10px);
    box-shadow: var(--shadow-lg);
  }
  .article-card a { text-decoration: none; color: inherit; display: block; }
  
  .article-image { height: 220px; overflow: hidden; position: relative; }
  .article-image img {
    width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s;
  }
  .article-card:hover .article-image img { transform: scale(1.1); }
  
  .article-category {
    position: absolute;
    top: 1rem; right: 1rem;
    background: var(--success);
    color: white;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 700;    font-family: 'Tajawal', sans-serif;
  }
  
  .article-content { padding: 1.8rem; }
  .article-content h3 {
    font-size: 1.3rem;
    color: var(--text);
    margin-bottom: 0.8rem;
    line-height: 1.4;
    font-family: 'Tajawal', sans-serif;
    font-weight: 700;
  }
  .article-content p {
    color: var(--text-light);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 1.2rem;
    font-family: 'Tajawal', sans-serif;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .article-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .article-meta time {
    color: var(--text-light);
    font-size: 0.9rem;
    font-family: 'Tajawal', sans-serif;
  }
  .read-time {
    color: var(--primary);
    font-weight: 600;
    font-size: 0.9rem;
    font-family: 'Tajawal', sans-serif;
  }

  .text-center { text-align: center; }

  /* ✅ CTA Section */
  .cta-section {
    padding: 6rem 0;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    text-align: center;  }
  .cta-content h2 {
    font-size: 2.8rem;
    margin-bottom: 1rem;
    font-family: 'Tajawal', sans-serif;
    font-weight: 800;
  }
  .cta-content p {
    font-size: 1.3rem;
    margin-bottom: 2.5rem;
    opacity: 0.95;
    font-family: 'Tajawal', sans-serif;
  }

  /* ✅ Responsive */
  @media (max-width: 968px) {
    .hero .container { grid-template-columns: 1fr; }
    .hero-image { display: none; }
    .about-grid { grid-template-columns: 1fr; }
    .about-image { order: -1; }
    .section-header { flex-direction: column; gap: 1rem; text-align: center; }
    .articles-grid { grid-template-columns: 1fr; }
  }
  
  @media (max-width: 768px) {
    .hero { padding: 4rem 0 3rem; min-height: auto; }
    .hero-title { font-size: 2.2rem; }
    .hero-subtitle { font-size: 1.1rem; }
    .section-title { font-size: 2rem; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .cta-content h2 { font-size: 2rem; }
    .cta-content p { font-size: 1.1rem; }
  }
</style>
