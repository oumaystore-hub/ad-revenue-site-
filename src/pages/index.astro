---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdHeader from '../components/AdHeader.astro';
import AdInContent from '../components/AdInContent.astro';
---
<BaseLayout title="الرئيسية - موقعي" description="أحدث المقالات والأخبار التقنية والثقافية">
  <AdHeader />
  <h1>مرحباً بك في موقعي</h1>
  <p>محتوى عربي أصيل، سريع التحميل، ومحسّن لقراءتك.</p>
  <section class="articles-grid" style="display: grid; gap: 1.5rem; margin: 2rem 0;">
    <article class="card" style="padding: 1.5rem; border: 1px solid #e5e7eb; border-radius: 8px; background: #fff;">
      <h2><a href="/articles/post-1">كيف تبدأ موقع ربحي من الصفر؟</a></h2>
      <p>دليل شامل لاختيار النطاق، الاستضافة المجانية، وقبول AdSense في أقل من شهر.</p>
      <a href="/articles/post-1" style="display:inline-block; margin-top:0.5rem; font-weight:500;">اقرأ المزيد ←</a>
    </article>
    <article class="card" style="padding: 1.5rem; border: 1px solid #e5e7eb; border-radius: 8px; background: #fff;">
      <h2><a href="/articles/post-2">أسرار تحسين Core Web Vitals</a></h2>
      <p>تقنيات عملية لرفع السرعة، تقليل الاهتزاز، وتحسين ترتيب جوجل.</p>
      <a href="/articles/post-2" style="display:inline-block; margin-top:0.5rem; font-weight:500;">اقرأ المزيد ←</a>
    </article>
  </section>
  <AdInContent />
</BaseLayout>
