---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

// 1. جلب جميع المقالات من مجلد articles
// المسار يبدأ بـ ./articles لأننا داخل مجلد pages مباشرة
const allPosts = await Astro.glob('./articles/post-*.astro');

// 2. دالة لاستخراج الرقم من اسم الملف (مثلاً post-10.astro -> 10)
const getPostNumber = (url) => {
  const match = url.match(/post-(\d+)\.astro/);
  return match ? parseInt(match[1], 10) : 0;
};

// 3. ترتيب المقالات رقمياً تنازلياً (الأحدث أولاً: 10، 9، 8... 1)
const sortedPosts = allPosts.sort((a, b) => {
  return getPostNumber(b.url) - getPostNumber(a.url);
});

const pageTitle = "TH Tech - الرئيسية";
const pageDescription = "بوابتك التقنية للذكاء الاصطناعي والربح الرقمي";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="home-container">
    <!-- ✅ قسم الترحيب -->
    <header class="hero">
      <h1>مرحباً بك في TH Tech</h1>
      <p>اكتشف أحدث التقنيات واستراتيجيات الربح الرقمي</p>
      <a href="#latest-posts" class="cta-button">تصفح المقالات</a>
    </header>

    <!-- ✅ قسم المقالات مرتبة رقمياً -->
    <section id="latest-posts" class="posts-section">
      <h2> أحدث المقالات</h2>
      <div class="posts-grid">
        {sortedPosts.map((post) => (
          <ArticleCard 
            title={post.frontmatter.pageTitle}
            description={post.frontmatter.description}
            image={post.frontmatter.articleImage}
            date={post.frontmatter.publishDate}
            category={post.frontmatter.category}
            url={post.url}
          />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home-container { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; }
  .hero { text-align: center; padding: 4rem 1rem; margin-bottom: 3rem; }
  .hero h1 { font-size: 3rem; color: #1e293b; margin-bottom: 1rem; }
  .hero p { font-size: 1.2rem; color: #64748b; margin-bottom: 2rem; }
  .cta-button { display: inline-block; padding: 1rem 2rem; background: #3b82f6; color: white; border-radius: 8px; text-decoration: none; font-weight: bold; transition: 0.3s; }
  .cta-button:hover { background: #1e40af; transform: translateY(-2px); }
  
  .posts-section h2 { font-size: 2rem; margin-bottom: 2rem; border-right: 4px solid #3b82f6; padding-right: 1rem; color: #1e293b; }
  .posts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem; }
  
  @media (max-width: 768px) {
    .posts-grid { grid-template-columns: 1fr; }
    .hero h1 { font-size: 2rem; }
  }
</style>
