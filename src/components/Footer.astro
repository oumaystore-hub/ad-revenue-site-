---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-content">
    <!-- فريق TH Tech -->
    <div class="team-section">
      <h3>👥 فريق TH Tech</h3>
      <p>فريق من الخبراء المتخصصين في التكنولوجيا، الذكاء الاصطناعي، والربح الرقمي</p>
      <div class="team-social">
        <a href="mailto:contact@thtech.com" class="team-link email" aria-label="Email">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
        <a href="https://instagram.com/thtech" target="_blank" rel="noopener noreferrer" class="team-link instagram" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/><line x1="12" x2="12.01" y1="6.5" y2="6.5"/><line x1="6.5" x2="6.51" y1="6.5" y2="6.5"/></svg>
        </a>
        <a href="https://twitter.com/thtech" target="_blank" rel="noopener noreferrer" class="team-link x" aria-label="X (Twitter)">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} TH Tech. جميع الحقوق محفوظة.</p>
      <p>بوابتك التقنية الموثوقة للذكاء الاصطناعي والربح الرقمي</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    color: #f1f5f9;
    margin-top: 5rem;
    padding: 3rem 0 2rem;
  }
  .footer-content { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  
  .team-section {
    text-align: center;
    padding: 2.5rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    margin-bottom: 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
  }
  .team-section h3 {
    font-size: 1.6rem;    margin: 0 0 1rem 0;
    color: #60a5fa;
    font-weight: 800;
  }
  .team-section p {
    color: #94a3b8;
    margin-bottom: 1.5rem;
    font-size: 1rem;
    line-height: 1.6;
  }
  .team-social {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
  }
  .team-link {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: all 0.3s;
    text-decoration: none;
  }
  .team-link svg {
    width: 18px;
    height: 18px;
  }
  .team-link.x { background: #000; border: 2px solid #333; }
  .team-link.x:hover { background: #333; transform: translateY(-5px); box-shadow: 0 8px 20px rgba(0,0,0,0.4); }
  .team-link.instagram {
    background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
    border: 2px solid transparent;
  }
  .team-link.instagram:hover { transform: translateY(-5px); box-shadow: 0 8px 20px rgba(220, 39, 67, 0.5); }
  .team-link.email { background: #ea4335; border: 2px solid #d33426; }
  .team-link.email:hover { background: #d33426; transform: translateY(-5px); box-shadow: 0 8px 20px rgba(234, 67, 53, 0.5); }
  
  .footer-bottom {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .footer-bottom p {
    margin: 0.5rem 0;
    color: #64748b;
    font-size: 0.9rem;
  }</style>
