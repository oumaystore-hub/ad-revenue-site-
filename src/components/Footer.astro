---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-content">
    <!-- فريق TH Tech مدمج -->
    <div class="team-section">
      <h3>👥 فريق TH Tech</h3>
      <p>فريق من الخبراء المتخصصين في التكنولوجيا، الذكاء الاصطناعي، والربح الرقمي</p>
      <div class="team-social">
        <a href="https://twitter.com/thtech" target="_blank" rel="noopener noreferrer" class="team-link x" aria-label="X">
          <i class="fa-brands fa-x-twitter"></i>
        </a>
        <a href="https://instagram.com/thtech" target="_blank" rel="noopener noreferrer" class="team-link instagram" aria-label="Instagram">
          <i class="fa-brands fa-instagram"></i>
        </a>
        <a href="mailto:contact@thtech.com" class="team-link email" aria-label="Email">
          <i class="fa-solid fa-envelope"></i>
        </a>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} TH Tech. جميع الحقوق محفوظة.</p>
      <p>بوابتك التقنية الموثوقة للذكاء الاصطناعي والربح الرقمي</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    color: #f1f5f9;
    margin-top: 5rem;
    padding: 3rem 0 2rem;
  }
  .footer-content { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  
  .team-section {
    text-align: center;
    padding: 2.5rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    margin-bottom: 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
  }
  .team-section h3 {
    font-size: 1.6rem;
    margin: 0 0 1rem 0;
    color: #60a5fa;
    font-weight: 800;
  }
  .team-section p {
    color: #94a3b8;
    margin-bottom: 1.5rem;
    font-size: 1rem;
    line-height: 1.6;
  }
  .team-social {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }
  .team-link {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.3rem;
    transition: all 0.3s;
    text-decoration: none;
  }
  .team-link.x { background: #000; border: 2px solid #333; }
  .team-link.x:hover { background: #333; transform: translateY(-5px); box-shadow: 0 8px 20px rgba(0,0,0,0.4); }
  .team-link.instagram {
    background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
    border: 2px solid transparent;
  }
  .team-link.instagram:hover { transform: translateY(-5px); box-shadow: 0 8px 20px rgba(220, 39, 67, 0.5); }
  .team-link.email { background: #ea4335; border: 2px solid #d33426; }
  .team-link.email:hover { background: #d33426; transform: translateY(-5px); box-shadow: 0 8px 20px rgba(234, 67, 53, 0.5); }
  
  .footer-bottom {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .footer-bottom p {
    margin: 0.5rem 0;
    color: #64748b;
    font-size: 0.9rem;
  }
</style>
