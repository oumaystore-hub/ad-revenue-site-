---
import SearchModal from './SearchModal.astro';
---

<header class="site-header">
  <div class="container">
    <a href="/ad-revenue-site" class="logo">TH Tech</a>
    
    <div class="header-actions">
      <button class="search-trigger" onclick="openSearch()" aria-label="بحث">
        <i class="fa-solid fa-magnifying-glass"></i>
      </button>
      
      <nav class="main-nav" id="nav">
        <button class="close-menu" onclick="document.getElementById('nav').classList.remove('active')">
          <i class="fa-solid fa-xmark"></i>
        </button>

        <ul class="nav-links">
          <li><a href="/ad-revenue-site" class="nav-item"><i class="fa-solid fa-house"></i><span>الرئيسية</span></a></li>
          <li><a href="/ad-revenue-site/articles" class="nav-item"><i class="fa-solid fa-newspaper"></i><span>المقالات</span></a></li>
          <li><a href="/ad-revenue-site/about" class="nav-item"><i class="fa-solid fa-user-group"></i><span>من نحن</span></a></li>
          <li><a href="/ad-revenue-site/contact" class="nav-item"><i class="fa-solid fa-envelope"></i><span>اتصل بنا</span></a></li>
        </ul>

        <div class="nav-categories-section">
          <span class="section-title">الأقسام</span>
          <div class="categories-grid">
            <a href="/ad-revenue-site/category/ai" class="cat-card">
              <div class="cat-icon-wrapper bg-ai">🤖</div>
              <span class="cat-name">ذكاء اصطناعي</span>
            </a>
            <a href="/ad-revenue-site/category/money" class="cat-card">
              <div class="cat-icon-wrapper bg-money">💰</div>
              <span class="cat-name">ربح رقمي</span>
            </a>
            <a href="/ad-revenue-site/category/tech" class="cat-card">
              <div class="cat-icon-wrapper bg-tech">💻</div>
              <span class="cat-name">تقنية</span>
            </a>
            <a href="/ad-revenue-site/category/performance" class="cat-card">
              <div class="cat-icon-wrapper bg-perf">🚀</div>
              <span class="cat-name">أداء</span>
            </a>
          </div>
        </div>
      </nav>

      <button class="mobile-toggle" onclick="document.getElementById('nav').classList.toggle('active')">
        <i class="fa-solid fa-bars-staggered"></i>      </button>
    </div>
  </div>
  
  <SearchModal />
</header>

<style>
  .site-header { background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); padding: 0.8rem 0; position: sticky; top: 0; z-index: 1000; box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; display: flex; justify-content: space-between; align-items: center; }
  .logo { font-family: 'Inter', sans-serif; font-weight: 900; font-size: 1.9rem; color: #fff; text-decoration: none; }
  .header-actions { display: flex; align-items: center; gap: 1rem; }
  .search-trigger { background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); color: white; width: 42px; height: 42px; border-radius: 12px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; transition: 0.3s; }
  .search-trigger:hover { background: rgba(255,255,255,0.3); transform: scale(1.05); }
  .main-nav ul { display: flex; gap: 0.5rem; list-style: none; margin: 0; padding: 0; }
  .nav-item { color: rgba(255,255,255,0.9); text-decoration: none; font-weight: 600; padding: 0.6rem 1.2rem; border-radius: 10px; transition: 0.3s; display: flex; align-items: center; gap: 0.6rem; }
  .nav-item:hover { background: rgba(255,255,255,0.2); color: white; }
  .close-menu, .nav-categories-section { display: none; }

  @media (max-width: 900px) {
    .main-nav { 
      display: none; position: fixed; top: 0; right: 0; width: 280px; height: 100vh; 
      background: #f8fafc; box-shadow: -5px 0 30px rgba(0,0,0,0.1); 
      padding: 4.5rem 1rem 1.5rem 1rem; z-index: 2000; overflow-y: auto;
    }
    .main-nav.active { display: block; }
    
    .close-menu {
      position: absolute; top: 1.2rem; left: 1rem;
      background: #e2e8f0; border: none; width: 36px; height: 36px; border-radius: 50%;
      font-size: 1.1rem; color: #475569; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
    }

    /* ✅ حل جذري: تحويل القائمة لشبكة 2x2 */
    .nav-links { 
      list-style: none; 
      padding: 0; 
      margin: 0; 
      display: grid !important;
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 10px !important;
    }
    .nav-links li { width: 100%; }
    
    .nav-item { 
      background: #ffffff; 
      padding: 1rem 0.5rem; 
      border-radius: 12px; 
      font-size: 0.85rem;       font-weight: 700; 
      flex-direction: column;
      text-align: center;
      border: 1px solid #e2e8f0;
      gap: 0.5rem;
    }
    .nav-item:hover { background: #eff6ff; border-color: #bfdbfe; color: #1e40af; }
    .nav-item i { font-size: 1.3rem; margin: 0; }
    .nav-item span { display: block; }
    
    .nav-categories-section { display: block; margin-top: 1.5rem; }
    .section-title { font-size: 0.8rem; color: #94a3b8; font-weight: 800; margin-bottom: 0.8rem; text-align: right; display: block; }
    
    .categories-grid { 
      display: grid; 
      grid-template-columns: repeat(2, 1fr); 
      gap: 10px; 
    }
    .cat-card {
      background: #ffffff; 
      border: 1px solid #e2e8f0; 
      border-radius: 12px;
      padding: 1rem 0.5rem; 
      text-decoration: none; 
      display: flex; 
      flex-direction: column; 
      align-items: center;
    }
    .cat-card:hover { transform: translateY(-2px); box-shadow: 0 4px 10px rgba(0,0,0,0.06); }
    
    .cat-icon-wrapper { 
      font-size: 1.8rem; 
      margin-bottom: 0.5rem; 
      width: 50px; 
      height: 50px; 
      display: flex; 
      align-items: center; 
      justify-content: center;
      border-radius: 50%;
    }
    .bg-ai { background: #dbeafe; }
    .bg-money { background: #dcfce7; }
    .bg-tech { background: #e0e7ff; }
    .bg-perf { background: #fef3c7; }
    
    .cat-name { color: #475569; font-weight: 700; font-size: 0.85rem; text-align: center; }
    
    .mobile-toggle { 
      display: flex; background: rgba(255,255,255,0.15); 
      border: 1px solid rgba(255,255,255,0.3); color: white;       width: 42px; height: 42px; border-radius: 12px; cursor: pointer; 
      align-items: center; justify-content: center; font-size: 1.2rem; 
    }
  }
</style>
