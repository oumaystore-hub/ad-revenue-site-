---
import SearchModal from './SearchModal.astro';
---

<header class="site-header">
  <div class="container">
    <a href="/ad-revenue-site" class="logo">TH Tech</a>
    
    <div class="header-actions">
      <button class="search-trigger" onclick="openSearch()" aria-label="بحث">
        <i class="fa-solid fa-magnifying-glass"></i>
      </button>
      
      <nav class="main-nav" id="nav">
        <!-- زر الإغلاق داخل القائمة للموبايل -->
        <button class="close-menu" onclick="document.getElementById('nav').classList.remove('active')">
          <i class="fa-solid fa-xmark"></i>
        </button>

        <ul class="nav-links">
          <li><a href="/ad-revenue-site" class="nav-item active"><i class="fa-solid fa-house"></i> الرئيسية</a></li>
          <li><a href="/ad-revenue-site/articles" class="nav-item"><i class="fa-solid fa-newspaper"></i> المقالات</a></li>
          <li><a href="/ad-revenue-site/about" class="nav-item"><i class="fa-solid fa-user-group"></i> من نحن</a></li>
          <li><a href="/ad-revenue-site/contact" class="nav-item"><i class="fa-solid fa-envelope"></i> اتصل بنا</a></li>
        </ul>

        <!-- قسم الأقسام بتصميم شبكي -->
        <div class="nav-categories-section">
          <span class="section-title">تصفح الأقسام</span>
          <div class="categories-grid">
            <a href="/ad-revenue-site/category/ai" class="cat-card">
              <span class="cat-icon bg-ai"></span>
              <span class="cat-name">ذكاء اصطناعي</span>
            </a>
            <a href="/ad-revenue-site/category/money" class="cat-card">
              <span class="cat-icon bg-money">💰</span>
              <span class="cat-name">ربح رقمي</span>
            </a>
            <a href="/ad-revenue-site/category/tech" class="cat-card">
              <span class="cat-icon bg-tech">💻</span>
              <span class="cat-name">تقنية</span>
            </a>
            <a href="/ad-revenue-site/category/performance" class="cat-card">
              <span class="cat-icon bg-perf">⚡</span>
              <span class="cat-name">أداء</span>
            </a>
          </div>
        </div>
      </nav>
      <button class="mobile-toggle" onclick="document.getElementById('nav').classList.toggle('active')">
        <i class="fa-solid fa-bars-staggered"></i>
      </button>
    </div>
  </div>
  
  <SearchModal />
</header>

<style>
  /* 🎨 تنسيق الهيدر العام */
  .site-header { 
    background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); 
    padding: 0.8rem 0; 
    position: sticky; 
    top: 0; 
    z-index: 1000; 
    box-shadow: 0 4px 20px rgba(0,0,0,0.1); 
  }
  .container { 
    max-width: 1200px; 
    margin: 0 auto; 
    padding: 0 1.5rem; 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
  }
  .logo { 
    font-family: 'Inter', sans-serif; 
    font-weight: 900; 
    font-size: 1.9rem; 
    color: #fff; 
    text-decoration: none; 
    letter-spacing: -0.5px;
  }
  .header-actions { display: flex; align-items: center; gap: 1rem; }
  
  /* زر البحث */
  .search-trigger { 
    background: rgba(255,255,255,0.15); 
    border: 1px solid rgba(255,255,255,0.3); 
    color: white; 
    width: 42px; height: 42px; 
    border-radius: 12px; 
    cursor: pointer; 
    display: flex; align-items: center; justify-content: center; 
    font-size: 1.2rem; 
    transition: all 0.3s; 
  }
  .search-trigger:hover { background: rgba(255,255,255,0.3); transform: scale(1.05); }  
  /* القائمة الرئيسية (للديسكتوب) */
  .main-nav ul { display: flex; gap: 0.5rem; list-style: none; margin: 0; padding: 0; }
  .nav-item { 
    color: rgba(255,255,255,0.9); 
    text-decoration: none; 
    font-weight: 600; 
    padding: 0.6rem 1.2rem; 
    border-radius: 10px; 
    transition: all 0.3s; 
    display: flex; align-items: center; gap: 0.5rem;
  }
  .nav-item:hover, .nav-item.active { background: rgba(255,255,255,0.2); color: white; }
  
  /* إخفاء أجزاء الموبايل في الديسكتوب */
  .close-menu, .nav-categories-section { display: none; }

  /* 📱 تنسيق الموبايل الاحترافي */
  @media (max-width: 900px) {
    .main-nav { 
      display: none; 
      position: fixed; 
      top: 0; right: 0; 
      width: 85%; /* عرض القائمة */
      max-width: 320px;
      height: 100vh; 
      background: rgba(255, 255, 255, 0.98); /* خلفية بيضاء نقية */
      backdrop-filter: blur(15px); /* تأثير الزجاج */
      padding: 2rem 1.5rem; 
      box-shadow: -10px 0 40px rgba(0,0,0,0.2); 
      z-index: 2000; 
      overflow-y: auto;
      animation: slideIn 0.3s ease-out;
    }
    
    @keyframes slideIn { from { transform: translateX(100%); } to { transform: translateX(0); } }
    .main-nav.active { display: block; }
    
    /* زر الإغلاق */
    .close-menu {
      position: absolute;
      top: 1.5rem; left: 1.5rem;
      background: #f1f5f9;
      border: none;
      width: 40px; height: 40px;
      border-radius: 50%;
      font-size: 1.2rem;
      color: #64748b;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;      transition: 0.3s;
    }
    .close-menu:hover { background: #e2e8f0; color: #0f172a; }

    /* الروابط */
    .nav-links { list-style: none; padding: 0; margin: 0 0 2rem 0; }
    .nav-links li { margin-bottom: 0.8rem; }
    .nav-item { 
      color: #334155; 
      background: transparent; 
      padding: 1rem; 
      border-radius: 12px; 
      font-size: 1.1rem; 
      font-weight: 700;
      display: flex; align-items: center; gap: 1rem;
    }
    .nav-item:hover { background: #f0f9ff; color: #0284c7; }
    .nav-item i { width: 24px; text-align: center; font-size: 1.2rem; color: #3b82f6; }
    
    /* قسم الأقسام الشبكي */
    .nav-categories-section { display: block; }
    .section-title { 
      display: block; 
      font-size: 0.85rem; 
      color: #94a3b8; 
      font-weight: 800; 
      text-transform: uppercase; 
      margin-bottom: 1rem; 
      letter-spacing: 1px;
    }
    .categories-grid {
      display: grid;
      grid-template-columns: 1fr 1fr; /* عمودين */
      gap: 12px;
    }
    .cat-card {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 14px;
      padding: 1.2rem 0.5rem;
      text-decoration: none;
      transition: all 0.2s;
      box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    }
    .cat-card:hover { transform: translateY(-3px); box-shadow: 0 5px 15px rgba(0,0,0,0.08); border-color: #bae6fd; }
    
    .cat-icon { 
      font-size: 1.8rem; 
      margin-bottom: 0.5rem;       width: 45px; height: 45px;
      display: flex; align-items: center; justify-content: center;
      border-radius: 50%;
    }
    /* ألوان خلفيات الأيقونات */
    .bg-ai { background: #e0e7ff; }
    .bg-money { background: #dcfce7; }
    .bg-tech { background: #dbeafe; }
    .bg-perf { background: #fef3c7; }

    .cat-name { 
      color: #475569; 
      font-weight: 700; 
      font-size: 0.95rem; 
    }
    
    .mobile-toggle { 
      display: flex; 
      background: rgba(255,255,255,0.15); 
      border: 1px solid rgba(255,255,255,0.3); 
      color: white; 
      width: 42px; height: 42px; 
      border-radius: 12px; 
      cursor: pointer; 
      align-items: center; justify-content: center; 
      font-size: 1.2rem; 
    }
  }
</style>
