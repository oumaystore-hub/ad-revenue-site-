---
const { headings = [] } = Astro.props;
---

{headings.length > 0 && (
  <div class="toc-wrapper">
    <!-- 🔵 الزر العائم -->
    <button class="toc-fab" id="tocFab" aria-label="عرض المحتويات">
      <i class="fa-solid fa-list-ul"></i>
    </button>

    <!-- 📑 القائمة المنبثقة المضيئة -->
    <nav class="toc-popup" id="tocPopup">
      <div class="toc-header">
        <h3>📑 المحتويات</h3>
        <button class="toc-close" id="tocClose">✕</button>
      </div>
      <ul>
        {headings.map(h => (
          <li>
            <a href={`#${h.slug}`}>{h.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
)}

<style>
  /* ✅ تنسيق الزر العائم */
  .toc-fab {
    position: fixed;
    bottom: 90px; /* فوق زر العودة للأعلى */
    left: 20px;
    width: 55px;
    height: 55px;
    border-radius: 50%;
    background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
    color: white;
    border: none;
    /* ✅ تأثير مضيء (Glowing) */
    box-shadow: 0 4px 15px rgba(59, 130, 246, 0.5), 0 0 20px rgba(59, 130, 246, 0.3);
    cursor: pointer;
    z-index: 1001;
    font-size: 1.3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }  .toc-fab:hover { transform: scale(1.1) rotate(5deg); }
  
  /* تغيير لون الزر عند فتح القائمة */
  .toc-fab.active { 
    background: #ef4444; 
    transform: rotate(45deg); 
    box-shadow: 0 4px 15px rgba(239, 68, 68, 0.5); 
  }

  /* ✅ تنسيق القائمة المنبثقة (Glassmorphism) */
  .toc-popup {
    position: fixed;
    bottom: 155px;
    left: 20px;
    width: 260px;
    max-height: 60vh;
    /* ✅ خلفية زجاجية */
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 20px;
    /* ✅ ظل مضيء */
    box-shadow: 0 10px 40px rgba(0,0,0,0.15), 0 0 15px rgba(59, 130, 246, 0.2);
    z-index: 1000;
    padding: 0;
    overflow: hidden;
    /* مخفي افتراضياً */
    opacity: 0;
    transform: translateY(20px) scale(0.9);
    pointer-events: none;
    transition: all 0.3s ease;
  }
  
  /* ظهور القائمة */
  .toc-popup.open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .toc-header {
    padding: 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #f1f5f9;
    background: rgba(255,255,255,0.5);
  }
  .toc-header h3 { margin: 0; font-size: 1rem; color: #1e293b; font-weight: 800; }
  .toc-close { background: none; border: none; font-size: 1.2rem; color: #64748b; cursor: pointer; padding: 5px; transition: 0.2s; }  .toc-close:hover { color: #ef4444; transform: rotate(90deg); }

  .toc-popup ul { list-style: none; padding: 0.5rem 0; margin: 0; overflow-y: auto; max-height: 50vh; }
  .toc-popup li { margin: 0; }
  
  .toc-popup a {
    display: block;
    padding: 0.6rem 1.2rem;
    color: #475569;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: background 0.2s, color 0.2s;
    border-right: 3px solid transparent;
  }
  .toc-popup a:hover {
    background: #eff6ff;
    color: #2563eb;
    border-right-color: #3b82f6;
  }

  /* إخفاء في الشاشات الكبيرة جداً (اختياري) */
  @media (min-width: 1200px) {
    .toc-fab, .toc-popup { display: none; }
  }
</style>

<script>
  const fab = document.getElementById('tocFab');
  const popup = document.getElementById('tocPopup');
  const closeBtn = document.getElementById('tocClose');
  
  if (fab && popup) {
    // ✅ فتح/إغلاق القائمة عند الضغط على الزر
    fab.addEventListener('click', () => {
      popup.classList.toggle('open');
      fab.classList.toggle('active');
    });
    
    // ✅ إغلاق القائمة بزر X
    if (closeBtn) {
      closeBtn.addEventListener('click', () => {
        popup.classList.remove('open');
        fab.classList.remove('active');
      });
    }
    
    // ✅ إغلاق القائمة + تمرير سلس عند اختيار عنوان
    popup.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', (e) => {        e.preventDefault(); // منع القفز المفاجئ
        const targetId = link.getAttribute('href');
        const targetElement = document.querySelector(targetId);
        
        if (targetElement) {
          targetElement.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
        
        // إغلاق القائمة بعد الاختيار
        popup.classList.remove('open');
        fab.classList.remove('active');
      });
    });
  }
</script>
