---
// 📑 جدول محتويات المقال — يُغلق تلقائياً عند النقر
---

<div class="table-of-contents" id="tableOfContents">
  <div class="toc-header">
    <h3>📑 محتويات المقال</h3>
  </div>
  <nav class="toc-list"><ul></ul></nav>
</div>

<style>
  .table-of-contents {
    position: fixed;
    top: 100px;
    right: 24px;
    width: 320px;
    max-height: calc(100vh - 120px);
    background: white;
    border-radius: 16px;
    border: 2px solid #e2e8f0;
    box-shadow: 0 15px 50px rgba(0,0,0,0.15);
    padding: 1.5rem;
    z-index: 998;
    opacity: 0;
    transform: translateX(20px) scale(0.95);
    pointer-events: none;
    transition: all 0.3s ease;
    overflow-y: auto;
  }
  .table-of-contents.active {
    opacity: 1;
    transform: translateX(0) scale(1);
    pointer-events: auto;
  }

  @media (max-width: 768px) {
    .table-of-contents {
      top: 80px;
      right: 16px;
      left: 16px;
      width: auto;
      max-height: 60vh;
    }
  }

  .toc-header {
    display: flex;
    justify-content: space-between;
    align-items: center;    margin-bottom: 1rem;
    padding-bottom: 0.8rem;
    border-bottom: 2px solid #e2e8f0;
  }
  .toc-header h3 { font-size: 1rem; color: #1e293b; margin: 0; font-weight: 700; }

  .toc-list ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc-list li {
    margin-bottom: 0.5rem;
  }
  .toc-list a {
    display: block;
    padding: 0.6rem 0.9rem;
    color: #475569;
    text-decoration: none;
    border-radius: 8px;
    font-size: 0.9rem;
    transition: all 0.2s;
    border-right: 3px solid transparent;
    line-height: 1.5;
  }
  .toc-list a:hover {
    background: #f1f5f9;
    color: #3b82f6;
    border-right-color: #3b82f6;
  }
  .toc-list a.active {
    background: #dbeafe;
    color: #1e40af;
    border-right-color: #3b82f6;
    font-weight: 600;
  }
  .toc-list .h3 {
    padding-right: 1.8rem;
    font-size: 0.85rem;
    color: #64748b;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const article = document.querySelector('.article-content');
    if (!article) return;

    const headings = article.querySelectorAll('h2, h3');
    const tocList = document.querySelector('.toc-list ul');
    if (headings.length === 0) {
      document.getElementById('tableOfContents').style.display = 'none';
      return;
    }

    headings.forEach((heading, index) => {
      if (!heading.id) heading.id = `heading-${index}`;
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#${heading.id}`;
      a.textContent = heading.textContent;
      a.classList.add(heading.tagName.toLowerCase());

      // ✅ عند النقر: اذهب إلى القسم + أغلق اللائحة تلقائياً
      a.addEventListener('click', (e) => {
        e.preventDefault();
        heading.scrollIntoView({ behavior: 'smooth', block: 'start' });

        // ⚡ إغلاق اللائحة تلقائياً بعد النقر
        document.getElementById('tableOfContents').classList.remove('active');
      });

      li.appendChild(a);
      tocList.appendChild(li);
    });

    // تتبع القسم النشط
    window.addEventListener('scroll', () => {
      let current = '';
      headings.forEach(h => {
        if (window.scrollY >= h.offsetTop - 150) current = h.id;
      });
      document.querySelectorAll('.toc-list a').forEach(link => {
        link.classList.remove('active');
        if (link.getAttribute('href') === `#${current}`) link.classList.add('active');
      });
    });
  });
</script>
