---
const { author } = Astro.props;
---

<div class="author-bio">
  <div class="author-avatar">
    <img src={author.avatar} alt={author.name} loading="lazy" />
  </div>
  <div class="author-info">
    <h3>{author.name}</h3>
    <p class="author-role">{author.role}</p>
    <p class="author-description">{author.bio}</p>
    <div class="author-social">
      {author.social?.twitter && (
        <a href={author.social.twitter} target="_blank" rel="noopener noreferrer" class="social-link x" aria-label="X (Twitter)">
          <i class="fa-brands fa-x-twitter"></i>
        </a>
      )}
      {author.social?.instagram && (
        <a href={author.social.instagram} target="_blank" rel="noopener noreferrer" class="social-link instagram" aria-label="Instagram">
          <i class="fa-brands fa-instagram"></i>
        </a>
      )}
      {author.social?.email && (
        <a href={`mailto:${author.social.email}`} class="social-link email" aria-label="Email">
          <i class="fa-solid fa-envelope"></i>
        </a>
      )}
    </div>
  </div>
</div>

<style>
  .author-bio {
    display: flex;
    gap: 1.5rem;
    padding: 2rem;
    background: #f8fafc;
    border-radius: 16px;
    margin: 3rem 0;
    border: 2px solid #e2e8f0;
    align-items: center;
  }
  .author-avatar {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 3px solid #3b82f6;
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
  }
  .author-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .author-info { flex: 1; }
  .author-info h3 { margin: 0 0 0.3rem 0; font-size: 1.3rem; color: #1e293b; font-weight: 800; }
  .author-role { margin: 0 0 0.6rem 0; color: #3b82f6; font-size: 0.9rem; font-weight: 600; }
  .author-description { margin: 0 0 1rem 0; color: #64748b; font-size: 0.9rem; line-height: 1.5; }
  
  .author-social {
    display: flex;
    gap: 0.7rem;
  }
  .social-link {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: white;
    font-size: 1.1rem;
    transition: all 0.3s;
  }
  .social-link.x { background: #000; }
  .social-link.x:hover { background: #333; transform: translateY(-3px); }
  .social-link.instagram { background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); }
  .social-link.instagram:hover { transform: translateY(-3px); box-shadow: 0 4px 12px rgba(220, 39, 67, 0.4); }
  .social-link.email { background: #ea4335; }
  .social-link.email:hover { background: #d33426; transform: translateY(-3px); }

  @media (max-width: 768px) {
    .author-bio { flex-direction: column; text-align: center; padding: 1.5rem; }
    .author-social { justify-content: center; }
  }
</style>
